<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:text="Navigation" />

    <!-- Navigation controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A2E"
        android:padding="8dp">

        <EditText
            android:id="@+id/et_destination"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Or long-press map to set destination"
            android:textColorHint="#777"
            android:textColor="@android:color/white"
            android:background="#2A2A3E"
            android:padding="8dp"
            android:textSize="12sp"
            android:inputType="text" />

        <Button
            android:id="@+id/btn_navigate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Go"
            android:textSize="12sp"
            android:backgroundTint="@color/colorAccent"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btn_stop_navigation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stop"
            android:textSize="12sp"
            android:backgroundTint="#F44336"
            android:enabled="false"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <com.google.android.gms.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tv_nav_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E2E"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:text="Long-press map to set destination, then tap Go" />

</LinearLayout>
